# Database (Supabase Postgres or any Postgres)
DATABASE_URL=postgresql://user:password@host:5432/cat_platform

# Auth.js
AUTH_SECRET=                       # `openssl rand -base64 32`
AUTH_URL=http://localhost:3000

# Email (Resend) for magic-link auth + editorial notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=editors@cat.org.in

# Supabase (optional, for Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Kimi (Moonshot) via NVIDIA's hosted API — primary LLM (free tier, OpenAI-compatible)
# Get at https://build.nvidia.com. Currently serves moonshotai/kimi-k2.6.
# Used by /agent preview and the draft writer.
NVIDIA_API_KEY=

# Anthropic Claude — only used by the discovery agent because it needs the
# Anthropic web_search tool, which NVIDIA's Kimi endpoint does not expose.
ANTHROPIC_API_KEY=

# Ingestion cost ceilings (USD)
AGENT_DAILY_USD_CEILING=5
INGESTION_RUN_USD_CEILING=10
